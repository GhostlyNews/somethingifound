local function serverSwitch()
    if not isGUIVisible() then return end
    info.Text = "✓ Switching servers and reloading script..."
    task.spawn(function()
        task.wait(0.5)
        
        -- Store current state to restore later
        local stateToSave = {
            antiFlingEnabled = antiFlingEnabled,
            antiKillEnabled = antiKillEnabled,
            antiBorderEnabled = antiBorderEnabled,
            autoSpawnPointEnabled = autoSpawnPointEnabled,
            currentSpeed = currentSpeed,
            dynamicFlyEnabled = dynamicFlyEnabled
        }
        
        -- Save state to global for reload
        _G.MenuState = stateToSave
        
        local ts = TeleportService
        local placeId = game.PlaceId
        pcall(function()
            local response = game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?limit=100")
            local data = HttpService:JSONDecode(response)
            local servers = {}
            if data and data.data then
                for _, v in pairs(data.data) do
                    if v.id ~= game.JobId then
                        table.insert(servers, v.id)
                    end
                end
            end
            if #servers > 0 then
                ts:TeleportToPlaceInstance(placeId, servers[math.random(1, #servers)], player)
            else
                ts:Teleport(placeId, player)
            end
        end)
    end)
end

