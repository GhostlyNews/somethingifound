-- Collect all UI elements and save their original values
local function collectAllUIElements()
    allFadeElements = {}
    originalValues = {}
    
    local function addElement(element, type, originalValue)
        table.insert(allFadeElements, {element = element, type = type, originalValue = originalValue})
    end
    
    -- Main frame and its strokes
    addElement(mainFrame, "BackgroundTransparency", mainFrame.BackgroundTransparency)
    addElement(stroke, "Transparency", stroke.Transparency)
    addElement(tabBar, "BackgroundTransparency", tabBar.BackgroundTransparency)
    addElement(tabStroke, "Transparency", tabStroke.Transparency)
    addElement(contentFrame, "BackgroundTransparency", contentFrame.BackgroundTransparency)
    addElement(contentStroke, "Transparency", contentStroke.Transparency)
    addElement(title, "TextTransparency", title.TextTransparency)
    addElement(info, "TextTransparency", info.TextTransparency)
    
    -- Tab buttons and their strokes
    for _, child in ipairs(tabBar:GetChildren()) do
        if child:IsA("TextButton") then
            addElement(child, "BackgroundTransparency", child.BackgroundTransparency)
            addElement(child, "TextTransparency", child.TextTransparency)
            for _, subChild in ipairs(child:GetChildren()) do
                if subChild:IsA("UIStroke") then
                    addElement(subChild, "Transparency", subChild.Transparency)
                end
            end
        end
    end
    
    -- Player list container
    addElement(playerListContainer, "BackgroundTransparency", playerListContainer.BackgroundTransparency)
    
    -- Anti container
    addElement(antiContainer, "BackgroundTransparency", antiContainer.BackgroundTransparency)
    
    -- Recursively collect all elements in anti container
    local function collectRecursive(obj)
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("Frame") then
                addElement(child, "BackgroundTransparency", child.BackgroundTransparency)
                collectRecursive(child)
            elseif child:IsA("TextButton") then
                addElement(child, "BackgroundTransparency", child.BackgroundTransparency)
                addElement(child, "TextTransparency", child.TextTransparency)
                for _, strokeChild in ipairs(child:GetChildren()) do
                    if strokeChild:IsA("UIStroke") then
                        addElement(strokeChild, "Transparency", strokeChild.Transparency)
                    end
                end
                collectRecursive(child)
            elseif child:IsA("TextLabel") then
                addElement(child, "TextTransparency", child.TextTransparency)
                collectRecursive(child)
            elseif child:IsA("TextBox") then
                addElement(child, "TextTransparency", child.TextTransparency)
                for _, strokeChild in ipairs(child:GetChildren()) do
                    if strokeChild:IsA("UIStroke") then
                        addElement(strokeChild, "Transparency", strokeChild.Transparency)
                    end
                end
                collectRecursive(child)
            elseif child:IsA("UIStroke") then
                addElement(child, "Transparency", child.Transparency)
            end
        end
    end
    collectRecursive(antiContainer)
    
    -- Functions container
    addElement(functionsContainer, "BackgroundTransparency", functionsContainer.BackgroundTransparency)
    collectRecursive(functionsContainer)
    
    -- Watermark
    if watermark then
        addElement(watermark, "TextTransparency", watermark.TextTransparency)
        addElement(watermark, "BackgroundTransparency", watermark.BackgroundTransparency)
    end
end

-- Fade In Function (Restores original values)
local function fadeIn()
    if fadeTween then fadeTween:Cancel() end
    
    -- Make GUI visible and interactable
    mainFrame.Visible = true
    mainFrame.Active = true
    mainFrame.Visible = true -- Ensure visibility
    
    -- Restore all elements to their original values
    for _, item in ipairs(allFadeElements) do
        pcall(function()
            if item.type == "BackgroundTransparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    BackgroundTransparency = item.originalValue
                })
                tween:Play()
            elseif item.type == "TextTransparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    TextTransparency = item.originalValue
                })
                tween:Play()
            elseif item.type == "Transparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    Transparency = item.originalValue
                })
                tween:Play()
            end
        end)
    end
end

-- Fade Out Function (Fully hides everything)
local function fadeOut()
    if fadeTween then fadeTween:Cancel() end
    
    -- Fade all elements to transparent
    for _, item in ipairs(allFadeElements) do
        pcall(function()
            if item.type == "BackgroundTransparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    BackgroundTransparency = 1
                })
                tween:Play()
            elseif item.type == "TextTransparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    TextTransparency = 1
                })
                tween:Play()
            elseif item.type == "Transparency" then
                local tween = TweenService:Create(item.element, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {
                    Transparency = 1
                })
                tween:Play()
            end
        end)
    end
    
    -- After fade, disable the frame so it can't be interacted with
    task.wait(0.1)
    mainFrame.Active = false
    mainFrame.Visible = false -- Hide completely to block clicks
end

-- Toggle GUI Function
local function toggleGUI()
    if isVisible then
        fadeOut()
        isVisible = false
    else
        fadeIn()
        isVisible = true
    end
end

-- Check if GUI is visible function
local function isGUIVisible()
