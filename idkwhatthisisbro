-- INSTANT ANTI-BORDER (formerly No-Clip)
local function enableAntiBorderInstant(char)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end

local function toggleAntiBorder()
    if not isGUIVisible() then return end -- Prevent toggling when hidden
    
    antiBorderEnabled = not antiBorderEnabled
    
    if antiBorderEnabled then
        local char = getCharacter()
        if char then
            enableAntiBorderInstant(char)
        end
        
        if antiBorderConnection then antiBorderConnection:Disconnect() end
        antiBorderConnection = RunService.RenderStepped:Connect(function()
            if antiBorderEnabled then
                local char = getCharacter()
                if char then
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part.CanCollide == true then
                            part.CanCollide = false
                        end
                    end
                end
            end
        end)
        
        info.Text = "✓ Anti-Border ON"
    else
        if antiBorderConnection then
            antiBorderConnection:Disconnect()
            antiBorderConnection = nil
        end
        
        local char = getCharacter()
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                    part.CanCollide = true
                end
            end
        end
        
        info.Text = "✗ Anti-Border OFF"
    end
    
    task.spawn(function()
        task.wait(0.3)
        if antiContainer and antiContainer.Visible and isVisible then
            info.Text = "Toggle switches for protection features"
        end
    end)
end

