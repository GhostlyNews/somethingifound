-- Dragging functions (only works when GUI is visible)
local function setupDragging()
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isVisible then
            dragging = true
            dragStart = input.Position
            startPos = mainFrame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    mainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and isVisible then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging and isVisible then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- SPEED LOCK SYSTEM - This keeps speed locked at all times
local function startSpeedLock()
    if speedLockConnection then
        speedLockConnection:Disconnect()
        speedLockConnection = nil
    end
    
    -- Use RenderStepped to constantly enforce the speed
    speedLockConnection = RunService.RenderStepped:Connect(function()
        if not speedLock then return end
        
        local char = getCharacter()
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid then
                -- Always set the speed to currentSpeed
                if humanoid.WalkSpeed ~= currentSpeed then
                    humanoid.WalkSpeed = currentSpeed
                end
            end
        end
    end)
end

-- Function to set player speed with permanent lock
local function setPlayerSpeed(speed)
    currentSpeed = tonumber(speed) or 16
    -- Clamp speed between 1 and 500
    if currentSpeed < 1 then currentSpeed = 1 end
    if currentSpeed > 500 then currentSpeed = 500 end
    
    -- Update humanoid immediately
    local char = getCharacter()
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = currentSpeed
    end
    
    -- Start speed lock to keep it permanent
    startSpeedLock()
    
    info.Text = "✓ Speed set to: " .. currentSpeed .. " (Locked)"
    task.spawn(function()
        task.wait(0.5)
        if antiContainer and antiContainer.Visible and isVisible then
            info.Text = "Toggle switches for protection features"
        elseif (not antiContainer or not antiContainer.Visible) and (not playerListContainer or not playerListContainer.Visible) and isVisible then
            info.Text = "ROBLOX MOCHA"
        end
    end)
end

-- Also listen for humanoid changes to ensure speed stays locked
local function monitorHumanoid()
    local char = getCharacter()
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        if humanoid then
            -- Connect to AttributeChanged to catch speed changes
            humanoid:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
                if speedLock then
                    -- If speed changed externally, force it back
                    if humanoid.WalkSpeed ~= currentSpeed then
                        humanoid.WalkSpeed = currentSpeed
                    end
                end
            end)
        end
    end
end

-- DYNAMIC FLY - Normal fly like Infinite Yield
local function setupDynamicFlyInputs()
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.W then movement.W = true end
        if input.KeyCode == Enum.KeyCode.A then movement.A = true end
        if input.KeyCode == Enum.KeyCode.S then movement.S = true end
        if input.KeyCode == Enum.KeyCode.D then movement.D = true end
        if input.KeyCode == Enum.KeyCode.Space then movement.Space = true end
        if input.KeyCode == Enum.KeyCode.LeftShift then movement.Shift = true end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.W then movement.W = false end
        if input.KeyCode == Enum.KeyCode.A then movement.A = false end
        if input.KeyCode == Enum.KeyCode.S then movement.S = false end
        if input.KeyCode == Enum.KeyCode.D then movement.D = false end
        if input.KeyCode == Enum.KeyCode.Space then movement.Space = false end
        if input.KeyCode == Enum.KeyCode.LeftShift then movement.Shift = false end
    end)
end

local function startDynamicFly()
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    -- Setup the movement input handlers if not already done
    if not _G.dynamicFlyInputsSetup then
        setupDynamicFlyInputs()
        _G.dynamicFlyInputsSetup = true
    end
    
    flyConnection = RunService.RenderStepped:Connect(function()
        if not dynamicFlyEnabled then return end
        
        local char = getCharacter()
        if not char then return end
        
        local humanoid = char:FindFirstChild("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        local camera = workspace.CurrentCamera
        
        if not humanoid or not rootPart or not camera then return end
        
        -- Create or get BodyVelocity
        local bodyVelocity = rootPart:FindFirstChild("FlyBodyVelocity")
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.Name = "FlyBodyVelocity"
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Velocity = Vector3.zero
            bodyVelocity.Parent = rootPart
        end
        
        -- Create or get BodyGyro
        local bodyGyro = rootPart:FindFirstChild("FlyBodyGyro")
        if not bodyGyro then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.Name = "FlyBodyGyro"
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.P = 10000
            bodyGyro.CFrame = rootPart.CFrame
            bodyGyro.Parent = rootPart
        end
        
        -- Calculate movement direction
        local direction = Vector3.zero
        
        if movement.W then direction = direction + camera.CFrame.LookVector end
        if movement.S then direction = direction - camera.CFrame.LookVector end
        if movement.A then direction = direction - camera.CFrame.RightVector end
        if movement.D then direction = direction + camera.CFrame.RightVector end
        if movement.Space then direction = direction + Vector3.new(0, 1, 0) end
        if movement.Shift then direction = direction - Vector3.new(0, 1, 0) end
        
        if direction.Magnitude > 0 then
            direction = direction.Unit * flySpeed
        end
        
        bodyVelocity.Velocity = direction
        bodyGyro.CFrame = camera.CFrame
        humanoid.PlatformStand = true
        
        -- Store references for cleanup
        flyBodyVelocity = bodyVelocity
        flyGyro = bodyGyro
    end)
end

local function stopDynamicFly()
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    local char = getCharacter()
    if char then
        local humanoid = char:FindFirstChild("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        
        if humanoid then
            humanoid.PlatformStand = false
        end
        
        -- Remove body velocity and gyro
        if rootPart then
            for _, child in ipairs(rootPart:GetChildren()) do
                if child:IsA("BodyVelocity") or child:IsA("BodyGyro") then
                    child:Destroy()
                end
            end
        end
    end
    
    -- Reset movement state
    movement.W = false
    movement.A = false
    movement.S = false
    movement.D = false
    movement.Space = false
    movement.Shift = false
end

local function toggleDynamicFly()
    if not isGUIVisible() then return end -- Prevent toggling when hidden
    
    dynamicFlyEnabled = not dynamicFlyEnabled
    
    if dynamicFlyEnabled then
        startDynamicFly()
        info.Text = "✓ Dynamic Fly ON - Use WASD/Space/Shift to move"
    else
        stopDynamicFly()
        info.Text = "✗ Dynamic Fly OFF"
    end
    
    task.spawn(function()
        task.wait(0.3)
        if antiContainer and antiContainer.Visible and isVisible then
            info.Text = "Toggle switches for protection features"
        end
    end)
end

-- Track death position
local function trackDeathPosition()
    local char = getCharacter()
    if not char then return end
    
    local humanoid = char:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    if humanoidConnection then
        humanoidConnection:Disconnect()
    end
    
    humanoidConnection = humanoid.Died:Connect(function()
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if rootPart and autoSpawnPointEnabled then
            lastDeathPosition = rootPart.CFrame
            info.Text = "✓ Death position saved!"
            task.spawn(function()
                task.wait(0.5)
                if antiContainer and antiContainer.Visible and isVisible then
                    info.Text = "Toggle switches for protection features"
                end
            end)
        end
    end)
end

-- INSTANT ANTI-FLING
local function disableCollisionsInstant(char)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanCollide = false
        end
    end
end

local function enableCollisionsInstant(char)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            part.CanCollide = true
        end
    end
end

local function toggleAntiFling()
    if not isGUIVisible() then return end -- Prevent toggling when hidden
    
    antiFlingEnabled = not antiFlingEnabled
    
    if antiFlingEnabled then
        local char = getCharacter()
        if char then
            disableCollisionsInstant(char)
        end
        
        if antiFlingConnection then antiFlingConnection:Disconnect() end
        antiFlingConnection = player.CharacterAdded:Connect(function(newChar)
            disableCollisionsInstant(newChar)
        end)
        
        info.Text = "✓ Anti-Fling ON"
    else
        if antiFlingConnection then
            antiFlingConnection:Disconnect()
            antiFlingConnection = nil
        end
        
        local char = getCharacter()
        if char then
            enableCollisionsInstant(char)
        end
        
        info.Text = "✗ Anti-Fling OFF"
    end
    
    task.spawn(function()
        task.wait(0.3)
        if antiContainer and antiContainer.Visible and isVisible then
            info.Text = "Toggle switches for protection features"
        elseif (not antiContainer or not antiContainer.Visible) and (not playerListContainer or not playerListContainer.Visible) and isVisible then
            info.Text = "ROBLOX MOCHA"
        end
    end)
end

