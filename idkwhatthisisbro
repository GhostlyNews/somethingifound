-- Collect all UI elements for fading (including watermark)
task.wait(0.1)
collectAllUIElements()

-- Fade in animation on startup
fadeIn()

-- Monitor humanoid for speed changes
task.wait(0.1)
monitorHumanoid()

-- Cleanup on player respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    if newChar then
        local rootPart = newChar:FindFirstChild("HumanoidRootPart")
        if rootPart then
            humanoidRootPart = rootPart
        end
        
        -- Monitor the new humanoid
        monitorHumanoid()
        
        -- Re-apply speed and restart lock
        task.wait(0.1)
        setPlayerSpeed(currentSpeed)
    end
    currentCharacter = newChar
    
    if autoSpawnPointEnabled then
        trackDeathPosition()
    end
    
    if antiFlingEnabled and newChar then
        disableCollisionsInstant(newChar)
    end
    
    if antiBorderEnabled and newChar then
        enableAntiBorderInstant(newChar)
    end
    
    -- Re-apply fly state on respawn
    if dynamicFlyEnabled and newChar then
        startDynamicFly()
    end
end)
