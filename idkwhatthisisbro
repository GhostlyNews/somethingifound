-- AUTO-SPAWNPOINT
local function toggleAutoSpawnPoint()
    if not isGUIVisible() then return end -- Prevent toggling when hidden
    
    autoSpawnPointEnabled = not autoSpawnPointEnabled
    
    if autoSpawnPointEnabled then
        trackDeathPosition()
        
        if spawnConnection then spawnConnection:Disconnect() end
        spawnConnection = player.CharacterAdded:Connect(function(newChar)
            trackDeathPosition()
            
            if lastDeathPosition then
                task.wait(0.1)
                local rootPart = newChar:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    rootPart.CFrame = lastDeathPosition
                    info.Text = "✓ Teleported to death location!"
                    task.spawn(function()
                        task.wait(0.5)
                        if antiContainer and antiContainer.Visible and isVisible then
                            info.Text = "Toggle switches for protection features"
                        end
                    end)
                end
            end
        end)
        
        info.Text = "✓ Auto-SpawnPoint ON - Tracking deaths"
    else
        if spawnConnection then
            spawnConnection:Disconnect()
            spawnConnection = nil
        end
        if humanoidConnection then
            humanoidConnection:Disconnect()
            humanoidConnection = nil
