-- Function to refresh the entire player list
local playerButtons = {}
local function refreshPlayerList()
    if not isGUIVisible() then return end
    
    local currentPlayers = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            currentPlayers[plr.Name] = plr
        end
    end
    
    for playerName, buttonObj in pairs(playerButtons) do
        if not currentPlayers[playerName] then
            buttonObj:Destroy()
            playerButtons[playerName] = nil
        end
    end
    
    for playerName, plr in pairs(currentPlayers) do
        if not playerButtons[playerName] then
            local newButton = createPlayerButton(playerName, plr)
            newButton.Parent = playerListContainer
            playerButtons[playerName] = newButton
        end
    end
    
    local layout = playerListContainer:FindFirstChild("ListLayout")
    if layout then
        local contentHeight = 0
        for _, child in ipairs(playerListContainer:GetChildren()) do
            if child:IsA("Frame") and child.Name:match("Button_") then
                contentHeight = contentHeight + child.Size.Y.Offset + layout.Padding.Offset
            end
        end
        playerListContainer.CanvasSize = UDim2.new(0, 0, 0, math.max(contentHeight, playerListContainer.Size.Y.Offset))
    end
end

